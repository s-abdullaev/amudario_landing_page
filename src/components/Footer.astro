---
import type { Locale } from '../i18n/locales';
import { useTranslations, getLocalizedPath } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="footer">
    <div class="container">
        <div class="footer-content">
            <div class="footer-brand">
                <img src="/images/logo/amudar-logo.png" alt="Amudar.io" height="28" style="height: 28px; width: auto;">
                <!-- <span>AMUDAR.IO</span> -->
            </div>
            <p class="footer-copy">&copy; {year} Amudario Research LLC. {t.footer.tagline}</p>
            <div class="footer-links">
                <a href={getLocalizedPath('/oxus-ws', lang)}>{t.nav.oxusWs}</a>
                <a href={getLocalizedPath('/jayhun-trap', lang)}>{t.nav.jayhunTrap}</a>
                <a href={getLocalizedPath('/oxus-airsense', lang)}>{t.nav.airsense}</a>
                <a href={getLocalizedPath('/gozanlink', lang)}>{t.nav.gozanlink}</a>
            </div>
            <div class="footer-socials">
                <a href="https://www.youtube.com/@AmudarIO" target="_blank" rel="noopener" aria-label="YouTube" title="YouTube">
                    <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8zM9.6 15.6V8.4L15.8 12l-6.2 3.6z"/></svg>
                </a>
                <a href="https://t.me/amudario" target="_blank" rel="noopener" aria-label="Telegram" title="Telegram">
                    <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M11.94 0A12 12 0 1 0 24 12 12 12 0 0 0 11.94 0zm5.87 8.16l-1.97 9.3c-.15.66-.54.82-1.09.51l-3-2.21-1.45 1.4a.76.76 0 0 1-.6.29l.21-3.06 5.57-5.03c.24-.21-.05-.33-.37-.12l-6.88 4.33-2.97-.92c-.64-.2-.66-.64.14-.95l11.6-4.47c.53-.2 1-.13.81.93z"/></svg>
                </a>
                <a href="https://www.linkedin.com/company/amudario-research-llc" target="_blank" rel="noopener" aria-label="LinkedIn" title="LinkedIn">
                    <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05a3.74 3.74 0 0 1 3.37-1.85c3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77A1.75 1.75 0 0 0 0 1.73v20.54A1.75 1.75 0 0 0 1.77 24h20.45A1.76 1.76 0 0 0 24 22.27V1.73A1.76 1.76 0 0 0 22.22 0z"/></svg>
                </a>
            </div>
        </div>
    </div>
</footer>
