---
import type { Locale } from '../i18n/locales';
import { useTranslations, getLocalizedPath } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<nav class="navbar" id="navbar">
    <div class="nav-container">
        <a class="nav-logo" href="#hero">
            <img src="/images/logo/amudar-logo.png" alt="Amudar.io Logo" height="40" style="height: 40px; width: auto;">
        </a>
        <ul class="nav-links" id="navLinks">
            <li><a href="#products">{t.nav.products}</a></li>
            <li><a href="#explode-section">{t.nav.oxusWs}</a></li>
            <li><a href="#jayhun-story">{t.nav.jayhunTrap}</a></li>
            <li><a href="#airsense-story">{t.nav.airsense}</a></li>
            <li><a href="#gozan-story">{t.nav.gozanlink}</a></li>
            <li><a href="#team">{t.nav.team}</a></li>
            <li><a href="#contact" class="nav-cta">{t.nav.contact}</a></li>
            <li class="nav-lang-item"><LanguageSwitcher lang={lang} currentPath={Astro.url.pathname} /></li>
        </ul>
        <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
            <span></span><span></span><span></span>
        </button>
    </div>
</nav>

<style>
    .nav-lang-item {
        margin-left: 0.5rem;
    }
</style>
