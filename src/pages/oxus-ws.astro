---
import ProductLayout from '../layouts/ProductLayout.astro';
---

<ProductLayout
  title="OXUS WS — Smart Agrometeostation | Amudar.io"
  description="OXUS WS is a smart agrometeostation with 30+ sensor parameters for precision weather monitoring, solar-powered, with real-time data via 4G/LoRa."
>
    <!-- HERO BANNER -->
    <section class="product-hero">
        <div class="product-hero-bg">
            <img src="/images/oxus-ws/banner.jpg" alt="OXUS WS Agrometeostation">
        </div>
        <div class="product-hero-content">
            <span class="section-tag">01 — Agrometeostation</span>
            <h1 class="section-title">OXUS <span class="gradient-text">WS</span></h1>
            <p class="product-hero-subtitle">
                Smart agrometeostation with 30+ sensor parameters for precision weather and crop monitoring — solar-powered, connected via 4G/LoRa.
            </p>
        </div>
    </section>

    <!-- PROBLEMS -->
    <section class="product-problems">
        <div class="container">
            <div class="section-header">
                <span class="section-tag reveal">The Challenge</span>
                <h2 class="section-title reveal">Why farmers need <span class="gradient-text">weather data</span></h2>
                <p class="section-subtitle reveal">Without real-time meteorological data, farmers face devastating consequences from unpredictable weather.</p>
            </div>
            <div class="product-problems-grid">
                <div class="product-problem-card reveal-up" style="--delay:0">
                    <div class="card-image">
                        <img src="/images/oxus-ws/problems/dead-crop.jpg" alt="Dead crops from frost">
                    </div>
                    <div class="card-body">
                        <h4>Unexpected Frost</h4>
                        <p>Lack of early frost warnings leads to catastrophic crop losses in cotton and wheat fields.</p>
                    </div>
                </div>
                <div class="product-problem-card reveal-up" style="--delay:1">
                    <div class="card-image">
                        <img src="/images/oxus-ws/problems/flooded.jpg" alt="Flooded field">
                    </div>
                    <div class="card-body">
                        <h4>Flood & Overwatering</h4>
                        <p>Without rain data, farmers cannot optimize irrigation, leading to waterlogged soil and root damage.</p>
                    </div>
                </div>
                <div class="product-problem-card reveal-up" style="--delay:2">
                    <div class="card-image">
                        <img src="/images/oxus-ws/problems/dried-up-crop.jpg" alt="Dried up crops">
                    </div>
                    <div class="card-body">
                        <h4>Drought & Heat Stress</h4>
                        <p>Rising temperatures without monitoring causes heat stress, reducing yields significantly.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FEATURES -->
    <section class="product-features">
        <div class="container">
            <div class="section-header">
                <span class="section-tag reveal">Features</span>
                <h2 class="section-title reveal">Precision <span class="gradient-text">monitoring</span> capabilities</h2>
                <p class="section-subtitle reveal">OXUS WS integrates multiple sensors to provide comprehensive agricultural and environmental data.</p>
            </div>
            <div class="features-grid">
                <div class="feature-card reveal-up" style="--delay:0">
                    <div class="feature-icon"><img src="/images/oxus-ws/icons/wind.png" alt="Wind monitoring"></div>
                    <h4>Wind Monitoring</h4>
                    <p>Measure wind speed and direction for crop protection and spray planning.</p>
                </div>
                <div class="feature-card reveal-up" style="--delay:1">
                    <div class="feature-icon"><img src="/images/oxus-ws/icons/rain.png" alt="Rainfall data"></div>
                    <h4>Rainfall Measurement</h4>
                    <p>Track precipitation in real time to optimize irrigation schedules and water usage.</p>
                </div>
                <div class="feature-card reveal-up" style="--delay:2">
                    <div class="feature-icon"><img src="/images/oxus-ws/icons/soil.png" alt="Soil monitoring"></div>
                    <h4>Soil Analysis</h4>
                    <p>Monitor soil moisture, temperature, and salinity to optimize crop health.</p>
                </div>
                <div class="feature-card reveal-up" style="--delay:3">
                    <div class="feature-icon"><img src="/images/oxus-ws/icons/dew-point.png" alt="Dew point"></div>
                    <h4>Dew Point & Humidity</h4>
                    <p>Track atmospheric humidity for disease prediction and frost risk assessment.</p>
                </div>
                <div class="feature-card reveal-up" style="--delay:4">
                    <div class="feature-icon"><img src="/images/oxus-ws/icons/analytics.png" alt="Data analytics"></div>
                    <h4>Data Analytics</h4>
                    <p>AI-powered insights turn raw sensor data into actionable farming recommendations.</p>
                </div>
                <div class="feature-card reveal-up" style="--delay:5">
                    <div class="feature-icon"><img src="/images/oxus-ws/icons/windsock.png" alt="Weather forecasting"></div>
                    <h4>Microclimate Forecasting</h4>
                    <p>Hyper-local weather predictions specific to your field, not the nearest city.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="product-how-it-works">
        <div class="container">
            <div class="section-header">
                <span class="section-tag reveal">How It Works</span>
                <h2 class="section-title reveal">From <span class="gradient-text">sensors</span> to <span class="gradient-text">decisions</span></h2>
            </div>
            <div class="how-content">
                <div class="how-image reveal-up">
                    <img src="/images/oxus-ws/how-it-works.png" alt="OXUS WS How It Works diagram">
                </div>
                <div class="how-text reveal-up" style="--delay:1">
                    <h3>Intelligent Data Pipeline</h3>
                    <p>
                        OXUS WS collects data from 30+ sensors installed in the field — measuring temperature, humidity, wind, rainfall, soil moisture, UV radiation, and more. Data is transmitted in real time via 4G or LoRa networks to our cloud platform, where machine learning models process the information and generate actionable insights including disease risk predictions, frost alerts, and optimal irrigation schedules. Farmers access everything through an intuitive web dashboard and mobile app.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- GALLERY -->
    <section class="product-gallery">
        <div class="container">
            <div class="section-header">
                <span class="section-tag reveal">Gallery</span>
                <h2 class="section-title reveal">OXUS WS <span class="gradient-text">in the field</span></h2>
            </div>
            <div class="gallery-grid reveal-up">
                <div class="gallery-item"><img src="/images/oxus-ws/gallery/field-01.jpg" alt="OXUS WS installation"></div>
                <div class="gallery-item"><img src="/images/oxus-ws/gallery/field-02.jpg" alt="OXUS WS in cotton field"></div>
                <div class="gallery-item"><img src="/images/oxus-ws/gallery/field-03.jpg" alt="OXUS WS sensors"></div>
                <div class="gallery-item"><img src="/images/oxus-ws/gallery/field-04.jpg" alt="OXUS WS in farm"></div>
                <div class="gallery-item"><img src="/images/oxus-ws/gallery/field-05.jpg" alt="OXUS WS close-up"></div>
                <div class="gallery-item"><img src="/images/oxus-ws/gallery/field-06.jpg" alt="OXUS WS deployed"></div>
                <div class="gallery-item"><img src="/images/oxus-ws/gallery/team-01.jpg" alt="OXUS WS team"></div>
                <div class="gallery-item"><img src="/images/oxus-ws/gallery/team-02.jpg" alt="OXUS WS assembly"></div>
            </div>
        </div>
    </section>

    <!-- DASHBOARD -->
    <section class="product-dashboard">
        <div class="container">
            <div class="section-header">
                <span class="section-tag reveal">Dashboard</span>
                <h2 class="section-title reveal">Real-time <span class="gradient-text">monitoring platform</span></h2>
            </div>
            <div class="dashboard-content">
                <div class="dashboard-images reveal-up">
                    <img src="/images/oxus-ws/dashboard/overview.png" alt="OXUS WS Dashboard overview">
                    <img src="/images/oxus-ws/dashboard/analytics.png" alt="OXUS WS Dashboard analytics">
                </div>
                <div class="dashboard-text reveal-up" style="--delay:1">
                    <h3>Intuitive Data Visualization</h3>
                    <p>Access all your field data through a powerful web dashboard and mobile application designed for farmers.</p>
                    <ul>
                        <li>Real-time sensor data with interactive charts and graphs</li>
                        <li>Historical data analysis with custom date ranges</li>
                        <li>Disease prediction models with risk level indicators</li>
                        <li>Automated alerts for frost, rain, wind, and extreme conditions</li>
                        <li>Multi-station management from a single dashboard</li>
                        <li>Exportable reports for agronomic planning</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- HARDWARE -->
    <section class="product-hardware">
        <div class="container">
            <div class="section-header">
                <span class="section-tag reveal">Hardware</span>
                <h2 class="section-title reveal">Built to <span class="gradient-text">withstand</span> the elements</h2>
            </div>
            <div class="hardware-content">
                <div class="hardware-text reveal-up">
                    <h3>Industrial-Grade Construction</h3>
                    <p>
                        OXUS WS is built with weather-resistant materials rated for outdoor use across all seasons. The station is powered entirely by a solar panel with a rechargeable battery, eliminating the need for grid electricity. It features a modular design allowing sensors to be added or replaced depending on specific crop requirements. Communication modules support both 4G cellular and LoRa long-range wireless, ensuring connectivity even in remote agricultural areas. Each station undergoes rigorous quality testing before deployment.
                    </p>
                </div>
                <div class="hardware-image reveal-up" style="--delay:1">
                    <img src="/images/oxus-ws/hardware.png" alt="OXUS WS Hardware Specifications">
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="product-cta">
        <div class="container">
            <div class="cta-content">
                <span class="section-tag reveal">Get Started</span>
                <h2 class="section-title reveal">Ready to monitor <span class="gradient-text">your fields?</span></h2>
                <p class="reveal">Contact us to learn how OXUS WS can transform your farming with precision weather data.</p>
                <div class="cta-buttons reveal-up">
                    <a href="/#contact" class="btn btn-primary">Contact Us</a>
                    <a href="/#products" class="btn btn-outline">View All Products</a>
                </div>
            </div>
        </div>
    </section>
</ProductLayout>
