---
// GozanLink product detail page
const P = "gozanlink"; // key into PRODUCTS_I18N
const IMG = "/assets/products/gozanlink";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GozanLink — Smart Greenhouse Management | Amudario</title>
  <meta name="description" content="GozanLink is an IoT greenhouse management system tracking temperature, humidity, CO2, light, and soil — with automated ventilation and irrigation control." />
  <link rel="icon" href="/assets/logo/FaviconTransparent.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <header class="nav" id="nav">
    <a class="nav__logo" href="/" aria-label="Amudario home">
      <img src="/assets/logo/amudar-logo.png" alt="Amudario" />
    </a>
    <nav class="nav__links">
      <a href="/products/oxus-ws">OxusWS</a>
      <a href="/products/jayhun-trap">JayhunTrap</a>
      <a href="/products/gozanlink">GozanLink</a>
      <a href="/products/oxus-airsense">AirSense</a>
    </nav>
    <div class="nav__right">
      <div class="langs">
        <button data-lang-btn="uz">UZ</button>
        <button data-lang-btn="ru">RU</button>
        <button data-lang-btn="en">EN</button>
      </div>
      <a href="/#contact" class="btn btn--dark nav__cta" data-i18n="nav.cta">Contact us</a>
    </div>
  </header>

  <main>
    <!-- hero -->
    <section class="pp-hero">
      <img class="pp-hero__bg" src={`${IMG}/banner.jpg`} alt="GozanLink in the field" />
      <div class="pp-hero__content" data-reveal>
        <span class="pp-hero__tag" data-i18n={`p:${P}.hero.tag`}>04 — Greenhouse</span>
        <h1 class="pp-hero__title" data-i18n={`p:${P}.hero.title`}>GozanLink</h1>
        <p class="pp-hero__tagline" data-i18n="gozan.tagline"></p>
        <p class="pp-hero__sub" data-i18n={`p:${P}.hero.subtitle`}>IoT greenhouse management system for precise climate control — monitoring temperature, humidity, CO₂, light, and soil with automated ventilation and irrigation.</p>
      </div>
    </section>

    <!-- problems -->
    <section class="pp-section">
      <div class="pp-section__head">
        <span class="eyebrow" data-i18n="p:sectionTags.theChallenge">The Challenge</span>
        <h2 class="pp-title" data-i18n={`p:${P}.problems.title`}>Greenhouses without smart control</h2>
        <p class="pp-sub" data-i18n={`p:${P}.problems.subtitle`}>Manual greenhouse management leads to inconsistent climate conditions, wasted resources, and suboptimal crop yields.</p>
      </div>
      <div class="pp-cards">
        {["frozen-plant.jpg", "dry-soil.jpg", "rotten-tomato.jpg"].map((img, i) => (
          <article class="pp-card" data-reveal style={`--rd:${i * 100}ms`}>
            <img src={`${IMG}/problems/${img}`} alt="" loading="lazy" />
            <h3 data-i18n={`p:${P}.problems.cards.${i}.title`}></h3>
            <p data-i18n={`p:${P}.problems.cards.${i}.desc`}></p>
          </article>
        ))}
      </div>
    </section>

    <!-- features -->
    <section class="pp-section--alt">
      <div class="pp-section">
        <div class="pp-section__head">
          <span class="eyebrow" data-i18n="p:sectionTags.features">Features</span>
          <h2 class="pp-title" data-i18n={`p:${P}.features.title`}>Complete greenhouse control</h2>
          <p class="pp-sub" data-i18n={`p:${P}.features.subtitle`}></p>
        </div>
        <div class="pp-cards pp-cards--6">
          {["f1-temp", "f2-humidity", "f3-co2", "f4-soil", "f5-irrigation", "f6-remote"].map((img, i) => (
            <article class="pp-card" data-reveal style={`--rd:${(i % 3) * 100}ms`}>
              <img src={`${IMG}/features/${img}.jpg`} alt="" loading="lazy" />
              <h3 data-i18n={`p:${P}.features.cards.${i}.title`}></h3>
              <p data-i18n={`p:${P}.features.cards.${i}.desc`}></p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- how it works -->
    <section class="pp-section">
      <div class="pp-split">
        <div data-reveal>
          <span class="eyebrow" data-i18n="p:sectionTags.howItWorks">How It Works</span>
          <h3 style="margin-top:.7rem" data-i18n={`p:${P}.howItWorks.heading`}>Intelligent Climate Management</h3>
          <p data-i18n={`p:${P}.howItWorks.text`}></p>
        </div>
        <img src={`${IMG}/live-dashboard.jpg`} alt="GozanLink greenhouse dashboard" loading="lazy" data-reveal style="--rd:120ms" />
      </div>
    </section>

    <!-- dashboard -->
    <section class="pp-section--alt">
      <div class="pp-section">
        <div class="pp-split">
          <img src={`${IMG}/dashboard/overview.jpg`} alt="GozanLink dashboard" loading="lazy" data-reveal />
          <div data-reveal style="--rd:120ms">
            <span class="eyebrow" data-i18n="p:sectionTags.dashboard">Dashboard</span>
            <h3 style="margin-top:.7rem" data-i18n={`p:${P}.dashboard.heading`}>Complete Greenhouse Command</h3>
            <p data-i18n={`p:${P}.dashboard.text`}></p>
            <ul>
              {[0, 1, 2, 3, 4, 5].map((i) => <li data-i18n={`p:${P}.dashboard.features.${i}`}></li>)}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- hardware -->
    <section class="pp-section">
      <div class="pp-split">
        <div data-reveal>
          <span class="eyebrow" data-i18n="p:sectionTags.hardware">Hardware</span>
          <h3 style="margin-top:.7rem" data-i18n={`p:${P}.hardware.heading`}>Modular Sensor Network</h3>
          <p data-i18n={`p:${P}.hardware.text`}></p>
        </div>
        <div class="spec-table" data-reveal style="--rd:120ms">
          <div class="spec-table__head">
            <span data-i18n="spec.param">Parameter</span>
            <span data-i18n="spec.range">Range</span>
          </div>
          {[
            ["gspec.l1", "Air temperature", "-40°C ~ +85°C"],
            ["gspec.l2", "Air humidity", "0% ~ 100%"],
            ["gspec.l3", "Boiler temperature (1st–3rd)", "0°C ~ +1024°C"],
            ["gspec.l4", "Pump control (1st, 2nd)", "1 – on, 0 – off", "gspec.v4"],
            ["gspec.l5", "Soil temperature", "-40°C ~ +80°C"],
            ["gspec.l6", "Soil moisture", "0% ~ 100%"],
            ["gspec.l7", "Soil electrical conductivity", "0 ~ 10 mS/cm"]
          ].map(([key, label, value, vkey]) => (
            <div class="spec-table__row">
              <span data-i18n={key}>{label}</span>
              <span class="spec-table__value" data-i18n={vkey || null}>{value}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- gallery -->
    <section class="pp-section">
      <div class="pp-section__head">
        <span class="eyebrow" data-i18n="p:sectionTags.gallery">Gallery</span>
        <h2 class="pp-title" data-i18n={`p:${P}.gallery.title`}>GozanLink installations</h2>
      </div>
      <div class="pp-gallery" data-reveal>
        {["greenhouse-01.jpg", "greenhouse-02.jpg", "greenhouse-03.jpg", "greenhouse-04.jpg", "greenhouse-05.jpg", "greenhouse-06.jpg"].map((img) => (
          <img src={`${IMG}/gallery/${img}`} alt="GozanLink deployment" loading="lazy" />
        ))}
      </div>
    </section>

    <!-- cta -->
    <section class="cta">
      <div class="cta__inner">
        <h2 class="cta__title" data-i18n={`p:${P}.cta.title`}>Optimize your greenhouse</h2>
        <p class="cta__body" data-i18n={`p:${P}.cta.text`}></p>
        <div class="cta__contacts">
          <a href="tel:+998909271177">+998 90 927 11 77</a>
          <a href="mailto:info@amudar.io">info@amudar.io</a>
          <a href="https://t.me/amudario" target="_blank" rel="noopener">t.me/amudario</a>
        </div>
        <div style="margin-top:2rem;position:relative">
          <a href="/" class="btn btn--light" data-i18n="common.back">Back to home</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="footer__brand">
      <img src="/assets/logo/amudar-logo.png" alt="Amudario" class="footer__logo" />
      <p data-i18n="footer.tagline">Smart solutions for smart agriculture.</p>
    </div>
    <div class="footer__cols">
      <div class="footer__col">
        <h4 data-i18n="footer.products">Products</h4>
        <a href="/products/oxus-ws">OxusWS</a>
        <a href="/products/jayhun-trap">JayhunTrap</a>
        <a href="/products/gozanlink">GozanLink</a>
        <a href="/products/oxus-airsense">AirSense</a>
      </div>
      <div class="footer__col">
        <h4 data-i18n="footer.company">Company</h4>
        <a href="/#solutions" data-i18n="nav.solutions">Solutions</a>
        <a href="/#team" data-i18n="footer.team">Team</a>
        <a href="/#partners" data-i18n="footer.partners">Partners</a>
      </div>
      <div class="footer__col">
        <h4 data-i18n="footer.contact">Contact</h4>
        <a href="tel:+998909271177">+998 90 927 11 77</a>
        <a href="mailto:info@amudar.io">info@amudar.io</a>
        <a href="https://t.me/amudario" target="_blank" rel="noopener">Telegram</a>
      </div>
    </div>
    <div class="footer__bottom">
      <span data-i18n="footer.rights">© 2026 Amudario Research LLC. All rights reserved.</span>
    </div>
  </footer>

  <script is:inline src="/js/products-i18n.js"></script>
  <script is:inline src="/js/i18n.js"></script>
  <script is:inline src="/js/scrub.js"></script>
</body>
</html>
