---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Amudar.io — Smart Solutions for Smart Agriculture"
  description="Amudar.io provides smart agrometeorological stations, pheromone traps, air quality monitoring devices, and greenhouse management systems for precision agriculture in Uzbekistan."
>
    <!-- THREE.JS BACKGROUND -->
    <div id="three-bg"></div>

    <!-- NAVIGATION -->
    <Navbar />

    <!-- HERO -->
    <section class="hero" id="hero">
        <div class="hero-content">
            <div class="hero-badge reveal">
                <span class="badge-dot"></span>
                Precision Agriculture Technology
            </div>
            <h1 class="hero-title">
                <span class="reveal reveal-delay-1">Smart Solutions</span>
                <span class="reveal reveal-delay-2">for Smart</span>
                <span class="reveal reveal-delay-3 gradient-text">Agriculture</span>
            </h1>
            <p class="hero-subtitle reveal reveal-delay-4">
                AI-powered agrometeorological stations, pest detection, air quality monitoring,
                and greenhouse management systems — transforming farming in Uzbekistan and beyond.
            </p>
            <div class="hero-actions reveal reveal-delay-5">
                <a href="#products" class="btn btn-primary">Explore Products</a>
                <a href="#contact" class="btn btn-outline">Get in Touch</a>
            </div>
            <div class="hero-stats reveal reveal-delay-5">
                <div class="stat">
                    <span class="stat-number" data-count="110">0</span><span class="stat-plus">+</span>
                    <span class="stat-label">Stations Installed</span>
                </div>
                <div class="stat">
                    <span class="stat-number" data-count="30">0</span><span class="stat-plus">+</span>
                    <span class="stat-label">Pest Models</span>
                </div>
                <div class="stat">
                    <span class="stat-number" data-count="20">0</span><span class="stat-plus">+</span>
                    <span class="stat-label">Agro Indicators</span>
                </div>
            </div>
        </div>
        <div class="scroll-indicator">
            <div class="scroll-mouse"><div class="scroll-wheel"></div></div>
            <span>Scroll to explore</span>
        </div>
    </section>

    <!-- SOLUTIONS -->
    <section class="solutions-section" id="products">
        <div class="container">
            <div class="section-header">
                <span class="section-tag reveal">Our Solutions</span>
                <h2 class="section-title reveal">Intelligent tools for <span class="gradient-text">precision farming</span></h2>
                <p class="section-subtitle reveal">Four interconnected smart systems that revolutionize agricultural monitoring, pest control, and environmental management.</p>
            </div>
            <div class="solutions-grid">
                <a href="#explode-section" class="solution-card reveal-up" style="--delay:0">
                    <div class="solution-number">01</div>
                    <h3>OXUS WS</h3>
                    <p>Smart agrometeostation with 30+ sensor parameters for precision weather monitoring.</p>
                </a>
                <a href="#jayhun-story" class="solution-card reveal-up" style="--delay:1">
                    <div class="solution-number">02</div>
                    <h3>JAYHUN TRAP</h3>
                    <p>AI-powered pheromone traps for automated pest detection and species counting.</p>
                </a>
                <a href="#airsense-story" class="solution-card reveal-up" style="--delay:2">
                    <div class="solution-number">03</div>
                    <h3>OXUS AIRSENSE</h3>
                    <p>Smart air quality monitoring with PM2.5/PM10 sensors and pollutant analysis.</p>
                </a>
                <a href="#gozan-story" class="solution-card reveal-up" style="--delay:3">
                    <div class="solution-number">04</div>
                    <h3>GOZANLINK</h3>
                    <p>IoT greenhouse management tracking temperature, humidity, CO₂, and light.</p>
                </a>
            </div>
        </div>
    </section>

    <!-- PRODUCT 1: OXUS WS — EXPLODE -->
    <section class="story-section" id="explode-section">
        <div class="story-sticky">
            <canvas class="story-canvas" id="explodeCanvas"></canvas>
            <div class="story-overlay">
                <div class="story-header">
                    <span class="section-tag">01 — Agrometeostation</span>
                    <h2 class="section-title">OXUS <span class="gradient-text">WS</span></h2>
                </div>
                <div class="story-facts" id="explodeFacts">
                    <div class="fact" data-appear="0.08">🌡️ Monitors air temp, humidity, precipitation, wind speed & direction</div>
                    <div class="fact" data-appear="0.20">🌱 Soil moisture, temperature & electrical conductivity sensors</div>
                    <div class="fact" data-appear="0.35">💧 Optimized watering schedule for cotton & wheat crops</div>
                    <div class="fact" data-appear="0.50">🦠 Predicts 10+ diseases & 20+ pest outbreak timings</div>
                    <div class="fact" data-appear="0.65">📊 Weekly agro-forecasts on real-time online dashboard</div>
                    <a href="/oxus-ws" class="fact fact-link" data-appear="0.78">Learn More</a>
                </div>
                <div class="story-progress"><div class="story-progress-fill" data-story="explode"></div></div>
                <div class="story-caption" id="explodeCaption">Helping cotton bolls ripen with precision data…</div>
            </div>
        </div>
    </section>

    <!-- PRODUCT 2: JAYHUN TRAP — MOTH STORY -->
    <section class="story-section" id="jayhun-story">
        <div class="story-sticky">
            <canvas class="story-canvas" id="jayhunCanvas"></canvas>
            <div class="story-overlay">
                <div class="story-header">
                    <span class="section-tag">02 — Pheromone Trap</span>
                    <h2 class="section-title">JAYHUN <span class="gradient-text">TRAP</span></h2>
                </div>
                <div class="story-facts" id="jayhunFacts">
                    <div class="fact" data-appear="0.08">📸 Wide-angle cameras continuously upload images to cloud</div>
                    <div class="fact" data-appear="0.20">🤖 AI-powered automatic pest detection & species classification</div>
                    <div class="fact" data-appear="0.35">🧪 Species-specific pheromone bait for targeted trapping</div>
                    <div class="fact" data-appear="0.50">☀️ Fully autonomous — solar-powered with GSM communication</div>
                    <div class="fact" data-appear="0.65">📊 Insect hazard assessment with species & development stages</div>
                    <a href="/jayhun-trap" class="fact fact-link" data-appear="0.78">Learn More</a>
                </div>
                <div class="story-progress"><div class="story-progress-fill" data-story="jayhun"></div></div>
                <div class="story-caption" id="jayhunCaption">Smart pheromone trap capturing moths…</div>
            </div>
        </div>
    </section>

    <!-- PRODUCT 3: OXUS AIRSENSE — SMOKE STORY -->
    <section class="story-section" id="airsense-story">
        <div class="story-sticky">
            <canvas class="story-canvas" id="airsenseCanvas"></canvas>
            <div class="story-overlay">
                <div class="story-header">
                    <span class="section-tag">03 — Air Quality</span>
                    <h2 class="section-title">OXUS <span class="gradient-text">AIRSENSE</span></h2>
                </div>
                <div class="story-facts" id="airsenseFacts">
                    <div class="fact" data-appear="0.08">💨 Measures NO₂, CO, NH₃, SO₂, H₂S & O₃ gases</div>
                    <div class="fact" data-appear="0.20">🔬 PM1.0, PM2.5 & PM10 particulate matter sensors</div>
                    <div class="fact" data-appear="0.35">🌡️ Tracks temperature, humidity, pressure & wind speed</div>
                    <div class="fact" data-appear="0.50">📡 GPS positioning with GSM/GPRS data transmission</div>
                    <div class="fact" data-appear="0.65">📊 Real-time online dashboard for air quality monitoring</div>
                    <a href="/oxus-airsense" class="fact fact-link" data-appear="0.78">Learn More</a>
                </div>
                <div class="story-progress"><div class="story-progress-fill" data-story="airsense"></div></div>
                <div class="story-caption" id="airsenseCaption">Analyzing urban air quality…</div>
            </div>
        </div>
    </section>

    <!-- PRODUCT 4: GOZANLINK — GREENHOUSE STORY -->
    <section class="story-section" id="gozan-story">
        <div class="story-sticky">
            <canvas class="story-canvas" id="gozanCanvas"></canvas>
            <div class="story-overlay">
                <div class="story-header">
                    <span class="section-tag">04 — Greenhouse</span>
                    <h2 class="section-title">GOZAN<span class="gradient-text">LINK</span></h2>
                </div>
                <div class="story-facts" id="gozanFacts">
                    <div class="fact" data-appear="0.08">🌡️ Internal & external temperature and humidity tracking</div>
                    <div class="fact" data-appear="0.20">🌱 Soil moisture, temperature & electrical conductivity</div>
                    <div class="fact" data-appear="0.35">💨 Wind speed & direction monitoring outside</div>
                    <div class="fact" data-appear="0.50">⚡ Power outage detection & pump control sensor</div>
                    <div class="fact" data-appear="0.65">📱 Emergency alerts via phone call & SMS</div>
                    <a href="/gozanlink" class="fact fact-link" data-appear="0.78">Learn More</a>
                </div>
                <div class="story-progress"><div class="story-progress-fill" data-story="gozan"></div></div>
                <div class="story-caption" id="gozanCaption">Monitoring greenhouse climate…</div>
            </div>
        </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="how-section" id="how-it-works">
        <div class="container">
            <div class="section-header">
                <span class="section-tag reveal">How It Works</span>
                <h2 class="section-title reveal">From <span class="gradient-text">field</span> to <span class="gradient-text">forecast</span></h2>
            </div>
            <div class="timeline">
                <div class="timeline-item reveal-left" style="--delay:0">
                    <div class="timeline-number">01</div>
                    <div class="timeline-content"><h3>Sensor Data Collection</h3><p>Weather parameters are measured by sensors and transmitted to the server via mobile networks.</p></div>
                </div>
                <div class="timeline-item reveal-right" style="--delay:1">
                    <div class="timeline-number">02</div>
                    <div class="timeline-content"><h3>Satellite Data Fusion</h3><p>Ground sensor data combines with satellite imagery for comprehensive environmental analysis.</p></div>
                </div>
                <div class="timeline-item reveal-left" style="--delay:2">
                    <div class="timeline-number">03</div>
                    <div class="timeline-content"><h3>AI Processing</h3><p>Machine learning models generate predictions for weather, disease, and pest outbreaks.</p></div>
                </div>
                <div class="timeline-item reveal-right" style="--delay:3">
                    <div class="timeline-number">04</div>
                    <div class="timeline-content"><h3>Farmer Dashboard</h3><p>Results displayed on an intuitive dashboard for real-time decision making.</p></div>
                </div>
            </div>
        </div>
    </section>

    <!-- TEAM -->
    <section class="team-section" id="team">
        <div class="container">
            <div class="section-header">
                <span class="section-tag reveal">Our Team</span>
                <h2 class="section-title reveal">World-class <span class="gradient-text">expertise</span></h2>
                <p class="section-subtitle reveal">Founded by university professors with decades of international research experience.</p>
            </div>
            <div class="team-grid">
                <div class="team-card reveal-up" style="--delay:0">
                    <div class="team-avatar"><img src="/images/team/jasurbek-khodjaev.jpg" alt="Jasurbek Khodjaev"></div>
                    <h3>Jasurbek Khodjayev</h3>
                    <span class="team-role">Co-Founder</span>
                    <ul class="team-credentials"><li>Inha University Professor</li><li>PhD in ICT Engineering, South Korea</li><li>15+ years R&D across 5 countries</li></ul>
                </div>
                <div class="team-card reveal-up" style="--delay:1">
                    <div class="team-avatar"><img src="/images/team/azizbek-marakhimov.jpg" alt="Azizbek Marakhimov"></div>
                    <h3>Azizbek Marakhimov</h3>
                    <span class="team-role">Co-Founder</span>
                    <ul class="team-credentials"><li>New Uzbekistan University Professor</li><li>PhD in Industrial Management</li><li>10+ years managing international projects</li></ul>
                </div>
                <div class="team-card reveal-up" style="--delay:2">
                    <div class="team-avatar"><img src="/images/team/sarvar-abdullaev.jpg" alt="Sarvar Abdullaev"></div>
                    <h3>Sarvar Abdullayev</h3>
                    <span class="team-role">Co-Founder</span>
                    <ul class="team-credentials"><li>Inha University Professor</li><li>PhD in CS, King's College London</li><li>12+ years R&D across 5 countries</li></ul>
                </div>
            </div>
        </div>
    </section>

    <!-- PARTNERS -->
    <section class="partners-section" id="partners">
        <div class="container">
            <div class="section-header">
                <span class="section-tag reveal">Our Partners</span>
                <h2 class="section-title reveal">Trusted by <span class="gradient-text">leading organizations</span></h2>
                <p class="section-subtitle reveal">We collaborate with top institutions and international bodies to deliver impact at scale.</p>
            </div>
            <div class="partners-grid reveal-up">
                <div class="partner-logo-card"><img src="/images/partners/undp.jpg" alt="United Nations Development Programme"></div>
                <div class="partner-logo-card"><img src="/images/partners/cgiar.png" alt="CGIAR"></div>
                <div class="partner-logo-card"><img src="/images/partners/icarda.png" alt="ICARDA"></div>
                <div class="partner-logo-card"><img src="/images/partners/ifad.jpg" alt="IFAD"></div>
                <div class="partner-logo-card"><img src="/images/partners/iwmi.png" alt="IWMI"></div>
                <div class="partner-logo-card"><img src="/images/partners/ifas.png" alt="IFAS"></div>
                <div class="partner-logo-card"><img src="/images/partners/inha-university.jpg" alt="Inha University in Tashkent"></div>
                <div class="partner-logo-card"><img src="/images/partners/new-uzbekistan-university.png" alt="New Uzbekistan University"></div>
                <div class="partner-logo-card"><img src="/images/partners/national-research-center.png" alt="National Research Center"></div>
                <div class="partner-logo-card"><img src="/images/partners/fanlar-akademiyasi.png" alt="Fanlar Akademiyasi"></div>
                <div class="partner-logo-card"><img src="/images/partners/uzhydromet.jpg" alt="Uzhydromet"></div>
                <div class="partner-logo-card"><img src="/images/partners/karantin-inspeksiya.jpg" alt="Karantin Inspeksiya"></div>
                <div class="partner-logo-card"><img src="/images/partners/chamber-of-commerce.jpg" alt="Chamber of Commerce and Industry"></div>
                <div class="partner-logo-card"><img src="/images/partners/tashkent-city.jpg" alt="Tashkent City"></div>
                <div class="partner-logo-card"><img src="/images/partners/suvchilar-maktabi.png" alt="Suvchilar Maktabi"></div>
                <div class="partner-logo-card"><img src="/images/partners/samarkand-marathon.png" alt="Samarkand Marathon"></div>
            </div>
        </div>
    </section>

    <!-- PRESS -->
    <section class="press-section" id="press">
        <div class="container">
            <div class="section-header">
                <span class="section-tag reveal">In the Press</span>
                <h2 class="section-title reveal">Recognized <span class="gradient-text">globally</span></h2>
            </div>
            <div class="press-marquee">
                <div class="marquee-track">
                    <a href="https://spot.uz/ru/2017/10/30/smart-farm/" target="_blank" class="press-card"><span class="press-source">Spot.uz</span><p>Farms in Tashkent region began implementing IoT</p></a>
                    <a href="http://www.uz.undp.org/content/uzbekistan/en/home/presscenter/articles/2019/02/13/undp-promotes-modern-eco-friendly-techniques-of-pest-and-disease.html" target="_blank" class="press-card"><span class="press-source">UNDP</span><p>UNDP promotes modern eco-friendly pest management</p></a>
                    <a href="https://www.spot.uz/ru/2019/03/15/meteo/" target="_blank" class="press-card"><span class="press-source">Spot.uz</span><p>Precision agriculture transforming farming in Uzbekistan</p></a>
                    <a href="https://www.gazeta.uz/ru/2019/02/13/ferlov/" target="_blank" class="press-card"><span class="press-source">Gazeta.uz</span><p>Pheromone traps help farmers fight pests</p></a>
                    <a href="https://inha.uz/general/amudario-research-llc-wins-first-place-in-cgiar-acceleration-program/" target="_blank" class="press-card"><span class="press-source">Inha.uz</span><p>Amudario wins first place in CGIAR Acceleration Program</p></a>
                    <a href="https://inha.uz/professors/professors-of-inha-university-in-tashkent-presented-smart-agrometeorological-stations/" target="_blank" class="press-card"><span class="press-source">Inha.uz</span><p>Professors present smart agrometeorological stations</p></a>
                    <!-- duplicated for seamless loop -->
                    <a href="https://spot.uz/ru/2017/10/30/smart-farm/" target="_blank" class="press-card"><span class="press-source">Spot.uz</span><p>Farms in Tashkent region began implementing IoT</p></a>
                    <a href="http://www.uz.undp.org/content/uzbekistan/en/home/presscenter/articles/2019/02/13/undp-promotes-modern-eco-friendly-techniques-of-pest-and-disease.html" target="_blank" class="press-card"><span class="press-source">UNDP</span><p>UNDP promotes modern eco-friendly pest management</p></a>
                    <a href="https://www.spot.uz/ru/2019/03/15/meteo/" target="_blank" class="press-card"><span class="press-source">Spot.uz</span><p>Precision agriculture transforming farming in Uzbekistan</p></a>
                    <a href="https://www.gazeta.uz/ru/2019/02/13/ferlov/" target="_blank" class="press-card"><span class="press-source">Gazeta.uz</span><p>Pheromone traps help farmers fight pests</p></a>
                    <a href="https://inha.uz/general/amudario-research-llc-wins-first-place-in-cgiar-acceleration-program/" target="_blank" class="press-card"><span class="press-source">Inha.uz</span><p>Amudario wins first place in CGIAR Acceleration Program</p></a>
                    <a href="https://inha.uz/professors/professors-of-inha-university-in-tashkent-presented-smart-agrometeorological-stations/" target="_blank" class="press-card"><span class="press-source">Inha.uz</span><p>Professors present smart agrometeorological stations</p></a>
                </div>
            </div>
        </div>
    </section>

    <!-- CONTACT -->
    <section class="contact-section" id="contact">
        <div class="container">
            <div class="contact-content">
                <div class="contact-text">
                    <span class="section-tag reveal">Get Started</span>
                    <h2 class="section-title reveal">Ready to transform <span class="gradient-text">your farm?</span></h2>
                    <p class="section-subtitle reveal">Contact us to learn how our smart solutions can boost your yields and protect your crops.</p>
                </div>
                <div class="contact-cards reveal-up">
                    <a href="tel:+998900350225" class="contact-card">
                        <div class="contact-card-icon"><svg viewBox="0 0 32 32" fill="none"><path d="M6 6h6l3 8-4 3c2 4 5 7 9 9l3-4 8 3v6c0 1-1 2-2 2C14 32 0 18 1 8c0-1 1-2 2-2h3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg></div>
                        <span class="contact-card-label">Call us</span>
                        <span class="contact-card-value">+998 90 035-02-25</span>
                    </a>
                    <a href="https://t.me/amudar_io" target="_blank" class="contact-card">
                        <div class="contact-card-icon"><svg viewBox="0 0 32 32" fill="none"><path d="M28 4L4 14l8 3 4 10 4-6 6 4L28 4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M12 17l10-8" stroke="currentColor" stroke-width="1.5"/></svg></div>
                        <span class="contact-card-label">Telegram</span>
                        <span class="contact-card-value">@amudar_io</span>
                    </a>
                    <a href="mailto:info@amudar.io" class="contact-card">
                        <div class="contact-card-icon"><svg viewBox="0 0 32 32" fill="none"><rect x="4" y="8" width="24" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M4 8l12 10L28 8" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg></div>
                        <span class="contact-card-label">Email</span>
                        <span class="contact-card-value">info@amudar.io</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <Footer />

    <script>
        import '../scripts/main';
    </script>
</BaseLayout>
