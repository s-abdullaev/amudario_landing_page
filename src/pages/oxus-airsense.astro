---
import ProductLayout from '../layouts/ProductLayout.astro';
---

<ProductLayout
  title="OXUS AIRSENSE — Air Quality Monitor | Amudar.io"
  description="OXUS AIRSENSE is a smart air quality monitoring station with PM2.5, PM10, CO2, SO2, and VOC sensors for urban and agricultural environments."
>
    <!-- HERO BANNER -->
    <section class="product-hero">
        <div class="product-hero-bg">
            <img src="/images/oxus-airsense/banner.jpg" alt="OXUS AIRSENSE Air Quality Monitor">
        </div>
        <div class="product-hero-content">
            <span class="section-tag">03 — Air Quality</span>
            <h1 class="section-title">OXUS <span class="gradient-text">AIRSENSE</span></h1>
            <p class="product-hero-subtitle">
                Smart air quality monitoring station with PM2.5, PM10, CO&#8322;, SO&#8322;, and VOC sensors — designed for urban, peri-urban, and agricultural zones.
            </p>
        </div>
    </section>

    <!-- PROBLEMS -->
    <section class="product-problems">
        <div class="container">
            <div class="section-header">
                <span class="section-tag reveal">The Challenge</span>
                <h2 class="section-title reveal">Why we need <span class="gradient-text">air quality data</span></h2>
                <p class="section-subtitle reveal">Air pollution is an invisible threat to public health, agriculture, and the environment — monitoring is the first step to action.</p>
            </div>
            <div class="product-problems-grid">
                <div class="product-problem-card reveal-up" style="--delay:0">
                    <div class="card-image"><img src="/images/oxus-airsense/problems/air-quality.jpg" alt="Poor air quality"></div>
                    <div class="card-body">
                        <h4>Urban Pollution</h4>
                        <p>Cities in Central Asia face hazardous air quality levels, especially during winter heating season.</p>
                    </div>
                </div>
                <div class="product-problem-card reveal-up" style="--delay:1">
                    <div class="card-image"><img src="/images/oxus-airsense/problems/traffic-exhaust.webp" alt="Traffic exhaust"></div>
                    <div class="card-body">
                        <h4>Traffic Emissions</h4>
                        <p>Vehicle exhaust is a major source of PM2.5 and NOx, impacting millions in urban corridors.</p>
                    </div>
                </div>
                <div class="product-problem-card reveal-up" style="--delay:2">
                    <div class="card-image"><img src="/images/oxus-airsense/problems/health-impact.jpg" alt="Health impact of air pollution"></div>
                    <div class="card-body">
                        <h4>Health Impacts</h4>
                        <p>Without monitoring, citizens have no data to protect themselves from hazardous air quality days.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FEATURES -->
    <section class="product-features">
        <div class="container">
            <div class="section-header">
                <span class="section-tag reveal">Features</span>
                <h2 class="section-title reveal">Comprehensive <span class="gradient-text">air analysis</span></h2>
                <p class="section-subtitle reveal">OXUS AIRSENSE measures a wide range of pollutants and environmental parameters for complete air quality assessment.</p>
            </div>
            <div class="features-grid">
                <div class="feature-card reveal-up" style="--delay:0">
                    <div class="feature-icon"><img src="/images/oxus-airsense/icons/pm-sensor.png" alt="PM monitoring"></div>
                    <h4>PM2.5 & PM10</h4>
                    <p>Laser-based particulate matter sensors for accurate real-time fine dust measurement.</p>
                </div>
                <div class="feature-card reveal-up" style="--delay:1">
                    <div class="feature-icon"><img src="/images/oxus-airsense/icons/pollution.png" alt="Gas detection"></div>
                    <h4>Gas Detection</h4>
                    <p>CO&#8322;, SO&#8322;, NO&#8322;, and VOC sensors for comprehensive atmospheric gas analysis.</p>
                </div>
                <div class="feature-card reveal-up" style="--delay:2">
                    <div class="feature-icon"><img src="/images/oxus-airsense/icons/parameters.png" alt="Environmental parameters"></div>
                    <h4>Environmental Parameters</h4>
                    <p>Temperature, humidity, and pressure sensors for complete meteorological context.</p>
                </div>
                <div class="feature-card reveal-up" style="--delay:3">
                    <div class="feature-icon"><img src="/images/icons/earth.png" alt="AQI calculation"></div>
                    <h4>Real-Time AQI</h4>
                    <p>Automatic Air Quality Index calculation following international standards (EPA, WHO).</p>
                </div>
                <div class="feature-card reveal-up" style="--delay:4">
                    <div class="feature-icon"><img src="/images/icons/cloud.png" alt="Cloud connectivity"></div>
                    <h4>Cloud Platform</h4>
                    <p>Real-time data synced to the cloud with historical analysis and trend visualization.</p>
                </div>
                <div class="feature-card reveal-up" style="--delay:5">
                    <div class="feature-icon"><img src="/images/icons/control.png" alt="Alert system"></div>
                    <h4>Smart Alerts</h4>
                    <p>Automated notifications when pollutant levels exceed safe thresholds for public safety.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="product-how-it-works">
        <div class="container">
            <div class="section-header">
                <span class="section-tag reveal">How It Works</span>
                <h2 class="section-title reveal">From <span class="gradient-text">air</span> to <span class="gradient-text">insight</span></h2>
            </div>
            <div class="how-content">
                <div class="how-image reveal-up">
                    <img src="/images/oxus-airsense/how-it-works.png" alt="OXUS AIRSENSE How It Works">
                </div>
                <div class="how-text reveal-up" style="--delay:1">
                    <h3>Continuous Air Monitoring</h3>
                    <p>
                        OXUS AIRSENSE continuously samples ambient air through precision intake ports, analyzing it with an array of electrochemical and laser-based sensors. Particulate matter (PM2.5, PM10) is measured using light-scattering technology, while gas sensors detect CO&#8322;, SO&#8322;, VOC, and other pollutants. Data is processed on-device and transmitted via 4G to our cloud platform where it is combined with weather data and satellite imagery for comprehensive air quality analysis. Results are displayed on public dashboards and mobile apps, with automated alerts for hazardous conditions.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- GALLERY -->
    <section class="product-gallery">
        <div class="container">
            <div class="section-header">
                <span class="section-tag reveal">Gallery</span>
                <h2 class="section-title reveal">AIRSENSE <span class="gradient-text">deployments</span></h2>
            </div>
            <div class="gallery-grid reveal-up">
                <div class="gallery-item"><img src="/images/oxus-airsense/gallery/installation-01.jpg" alt="AIRSENSE installation"></div>
                <div class="gallery-item"><img src="/images/oxus-airsense/gallery/installation-02.jpg" alt="AIRSENSE unit"></div>
                <div class="gallery-item"><img src="/images/oxus-airsense/gallery/installation-03.jpg" alt="AIRSENSE close-up"></div>
                <div class="gallery-item"><img src="/images/oxus-airsense/gallery/installation-05.jpg" alt="AIRSENSE deployed"></div>
                <div class="gallery-item"><img src="/images/oxus-airsense/gallery/device-overview.png" alt="AIRSENSE overview"></div>
            </div>
        </div>
    </section>

    <!-- DASHBOARD -->
    <section class="product-dashboard">
        <div class="container">
            <div class="section-header">
                <span class="section-tag reveal">Dashboard</span>
                <h2 class="section-title reveal">Air quality <span class="gradient-text">intelligence</span></h2>
            </div>
            <div class="dashboard-content">
                <div class="dashboard-images reveal-up">
                    <img src="/images/oxus-airsense/dashboard/overview.png" alt="AIRSENSE Dashboard">
                </div>
                <div class="dashboard-text reveal-up" style="--delay:1">
                    <h3>Comprehensive AQI Platform</h3>
                    <p>The OXUS AIRSENSE dashboard delivers actionable air quality intelligence to cities, communities, and agricultural operations.</p>
                    <ul>
                        <li>Real-time AQI display with color-coded health risk levels</li>
                        <li>Individual pollutant breakdown — PM2.5, PM10, CO&#8322;, SO&#8322;, VOC</li>
                        <li>Historical trend analysis with hourly, daily, and monthly views</li>
                        <li>Interactive maps showing air quality across monitoring network</li>
                        <li>Public-facing displays for community awareness</li>
                        <li>Automated health advisory notifications</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- HARDWARE -->
    <section class="product-hardware">
        <div class="container">
            <div class="section-header">
                <span class="section-tag reveal">Hardware</span>
                <h2 class="section-title reveal">Professional-grade <span class="gradient-text">monitoring station</span></h2>
            </div>
            <div class="hardware-content">
                <div class="hardware-text reveal-up">
                    <h3>Precision Air Quality Station</h3>
                    <p>
                        OXUS AIRSENSE is housed in a compact, weather-resistant enclosure designed for permanent outdoor installation. The station integrates multiple sensor types — laser particle counters for PM2.5/PM10, NDIR sensors for CO&#8322;, electrochemical cells for SO&#8322; and NO&#8322;, and photoionization detectors for VOCs. A built-in heating element prevents condensation in cold weather. The system communicates via 4G/Wi-Fi and runs on solar or mains power. Automated self-diagnostics ensure consistent measurement accuracy over time.
                    </p>
                </div>
                <div class="hardware-image reveal-up" style="--delay:1">
                    <img src="/images/oxus-airsense/hardware.png" alt="OXUS AIRSENSE Hardware Specifications">
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="product-cta">
        <div class="container">
            <div class="cta-content">
                <span class="section-tag reveal">Get Started</span>
                <h2 class="section-title reveal">Monitor the air <span class="gradient-text">you breathe</span></h2>
                <p class="reveal">Contact us to deploy OXUS AIRSENSE in your city, campus, or agricultural region.</p>
                <div class="cta-buttons reveal-up">
                    <a href="/#contact" class="btn btn-primary">Contact Us</a>
                    <a href="/#products" class="btn btn-outline">View All Products</a>
                </div>
            </div>
        </div>
    </section>
</ProductLayout>
